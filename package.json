{
    "name": "@voltstack/vpm",
    "version": "1.0.0",
    "description": "VoltCloud plugin registry CLI",
    "license": "MIT",
    "type": "module",
    "bin": {
        "vpm": "bin/vpm.js"
    },
    "files": [
        "bin",
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --external:keytar --external:@mongodb-js/zstd --banner:js=\"import { createRequire } from 'node:module'; const require = createRequire(import.meta.url);\"",
        "dev": "tsx src/index.ts",
        "typecheck": "tsc --noEmit",
        "prepublishOnly": "npm run build"
    },
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "@mongodb-js/zstd": "1.2.2",
        "chalk": "5.3.0",
        "commander": "12.1.0",
        "conf": "13.1.0",
        "keytar": "7.9.0",
        "kleur": "4.1.5",
        "ora": "8.1.1",
        "semver": "7.6.3",
        "tar": "7.4.3",
        "undici": "6.21.0",
        "zod": "3.23.8"
    },
    "devDependencies": {
        "@types/node": "20.14.10",
        "@types/semver": "7.5.8",
        "@types/tar": "6.1.13",
        "esbuild": "0.23.1",
        "tsx": "4.19.2",
        "typescript": "5.5.4"
    }
}
